   "source": [
    "def fib(n):\n",
    "    if n==1:\n",
    "        return 0\n",
    "    if n==2:\n",
    "        return 1\n",
    "    \n",
    "    return fib(n-1)+fib(n-2)\n",
    "n=int(input(\"enter the number:\"))\n",
    "num=n\n",
    "fib(num)\n",
    "\n",
    "    "
   ]
