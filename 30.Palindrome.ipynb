   "source": [
    "num=int(input(\"enter the number:\"))\n",
    "original=num\n",
    "reverse=0\n",
    "while(num>0):\n",
    "    rem=num%10\n",
    "    reverse=reverse*10+rem;\n",
    "    num//=10;\n",
    "if(original==reverse):\n",
    "    print(\"The given number is palindrome\")\n",
    "else:\n",
    "    print(\"The given number not a palindrome\")"
   ]
  },
