      "enter the number123\n"
     ]
    },
    {
     "data": {
      "text/plain": [
       "4"
      ]
     },
     "execution_count": 4,
     "metadata": {},
     "output_type": "execute_result"
    }
   ],
   "source": [
    "def sum(num):\n",
    "    last=num%10\n",
    "    while num>10:\n",
    "        num=num//10\n",
    "    sum=last+num\n",
    "    return sum\n",
    "num=int(input(\"enter the number\"))\n",
    "sum(num)\n"
   ]
  },
