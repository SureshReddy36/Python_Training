   "source": [
    "//Calculate the sum of the digits of a number which is taken as input from the user"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 6,
   "id": "6f62c7d8",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "enter the number:123\n",
      "The sum of the digits: 6\n"
     ]
    }
   ],
   "source": [
    "num=int(input(\"enter the number:\"))\n",
    "sum=0\n",
    "while(num>0):\n",
    "    rem=num%10\n",
    "    sum=sum+rem\n",
    "    num=num//10\n",
    "print(\"The sum of the digits:\",sum)\n",
    "    "
   ]
