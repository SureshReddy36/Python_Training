   ],
   "source": [
    "def SumofDig(num):\n",
    "    if num == 0:\n",
    "        return 0\n",
    "    \n",
    "    rem = num % 10\n",
    "    return rem + SumofDig(num // 10)\n",
    "\n",
    "num = int(input(\"Enter the number: \"))\n",
    "result = SumofDig(num)\n",
    "print(\"Sum of digits:\", result)\n"
   ]
  },
