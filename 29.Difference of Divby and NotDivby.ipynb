   "id": "621552ad",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "285\n"
     ]
    }
   ],
   "source": [
    "divby=0\n",
    "notdivby=0\n",
    "for i in range(1,31):\n",
    "    if(i%6==0):\n",
    "        divby=divby+i\n",
    "    else:\n",
    "        notdivby=notdivby+i\n",
    "diff=notdivby-divby\n",
    "print(diff)"
   ]
